generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  status      String   @default("Planning") // Planning | In Progress | Blocked | Testing | Done
  priority    String   @default("Medium")   // Low | Medium | High
  progress    Int      @default(0)          // 0-100
  dueDate     DateTime?
  tags        String   @default("")         // comma-separated
  notes       String   @default("")         // markdown
  archived    Boolean  @default(false)
  directory   String   @default("")         // linked folder path
  lastScannedAt DateTime?                   // last auto-scan timestamp
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks      Task[]
  activities ActivityLog[]
}

model Task {
  id        String   @id @default(cuid())
  text      String
  completed Boolean  @default(false)
  order     Int      @default(0)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  action    String   // e.g. "Status changed from Planning to In Progress"
  createdAt DateTime @default(now())
}
