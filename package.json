{
  "name": "project-tracker",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:reset": "npx prisma migrate reset --force && npx tsx prisma/seed.ts",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:build": "next build && electron-builder --mac",
    "electron:pack": "next build && electron-builder --mac --dir"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "build": {
    "appId": "com.projecttracker.app",
    "productName": "Project Tracker",
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg",
      "icon": "electron/icon.icns"
    },
    "files": [
      "electron/**/*",
      ".next/**/*",
      "public/**/*",
      "node_modules/**/*",
      "package.json",
      "prisma/**/*",
      "src/generated/**/*"
    ],
    "extraResources": [
      {
        "from": "prisma",
        "to": "prisma"
      }
    ],
    "directories": {
      "output": "dist-electron"
    }
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "next": "16.2.7",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^35.7.5",
    "electron-builder": "^26.15.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
